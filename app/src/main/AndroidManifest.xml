<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for posting notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for the receipt scanner camera feature -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!--
        Custom signature-level permission (L7).
        Only apps signed with the same developer key as SecureSpend can access expense data via
        the ContentProvider, preventing unauthorised third-party apps from reading financial data.
    -->
    <permission
        android:name="com.f430947.securespend.EXPENSE_DATA"
        android:label="Access SecureSpend Expense Data"
        android:protectionLevel="signature" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SecureSpend">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SecureSpend">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ContentProvider secured with the custom signature permission (L7).
            Exposes expense data only to apps signed by the same developer key.
        -->
        <provider
            android:name=".data.ExpenseContentProvider"
            android:authorities="com.f430947.securespend.provider"
            android:exported="true"
            android:readPermission="com.f430947.securespend.EXPENSE_DATA"
            android:writePermission="com.f430947.securespend.EXPENSE_DATA" />

    </application>

</manifest>
